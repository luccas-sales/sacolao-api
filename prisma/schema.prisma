generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model suppliers {
  id                Int     @id @default(autoincrement())
  tax_id            String  @unique(map: "uq_suppliers_tax_id") @db.VarChar(14)
  legal_name        String  @db.VarChar
  legal_nature      String? @db.VarChar
  legal_description String? @db.VarChar
  sector            String  @db.VarChar
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model notes_rural_suppliers {
  id                 Int       @id @default(autoincrement())
  supplier_tax_id    String    @db.VarChar
  supplier_name      String?   @db.VarChar
  sector             String?   @db.VarChar
  note               String?   @db.VarChar
  note_access_key    String?   @db.VarChar(44)
  note_date          DateTime? @db.Timestamptz(6)
  issuer_tax_id      String?   @db.VarChar
  store_name         String?   @db.VarChar
  receipt            String?   @db.VarChar
  receipt_access_key String?   @db.VarChar(44)
  receipt_date       DateTime? @db.Timestamptz(6)
  value              String?   @db.VarChar
  status             String?   @default("000") @db.VarChar
  is_duplicate       Boolean?  @default(false)
  created_at         DateTime? @default(now()) @db.Timestamptz(6)
}
